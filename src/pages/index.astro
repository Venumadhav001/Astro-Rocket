---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="HySPERA — Hydrogen Fuel Cell Electric Vehicle"
  description="HySPERA is building India's first premium hydrogen fuel cell passenger car. Driven by Hydrogen. Defined by Innovation."
>

  <!-- HERO -->
  <section style="min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; background:#f8fafc; padding: 80px 40px; text-align:center;">
    <p style="font-size:11px; letter-spacing:0.3em; color:#0ea5e9; text-transform:uppercase; margin-bottom:24px;">
      Hydrogen Fuel Cell Electric Vehicle
    </p>
    <h1 style="font-size:clamp(2.5rem, 6vw, 5rem); font-weight:700; color:#0a0f1e; line-height:1.1; max-width:900px; margin-bottom:24px;">
      Driven by Hydrogen.<br/>
      <span style="color:#0ea5e9;">Defined by Innovation.</span>
    </h1>
    <p style="font-size:1.1rem; color:#475569; max-width:560px; line-height:1.8; margin-bottom:48px;">
      India's first premium hydrogen fuel cell passenger car.
      Built for long-distance mobility without compromise.
    </p>
    <div style="display:flex; gap:16px; flex-wrap:wrap; justify-content:center;">
      <a href="/vehicle" style="background:#0ea5e9; color:white; padding:16px 36px; font-size:12px; letter-spacing:0.15em; text-transform:uppercase; text-decoration:none; font-weight:500;">
        Explore the Vehicle
      </a>
      <a href="/technology" style="border:1px solid #cbd5e1; color:#0a0f1e; padding:16px 36px; font-size:12px; letter-spacing:0.15em; text-transform:uppercase; text-decoration:none; font-weight:500;">
        Our Technology
      </a>
    </div>
  </section>

  <!-- STATS -->
  <section style="background:#0a0f1e; padding:80px 40px;">
    <div style="max-width:1100px; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:0;">
      
      <div style="padding:40px; text-align:center; border-right:1px solid #1e293b;">
        <div style="font-size:3rem; font-weight:700; color:white;">550–650</div>
        <div style="color:#0ea5e9; font-size:12px; letter-spacing:0.2em; text-transform:uppercase; margin-top:4px;">km</div>
        <div style="color:#475569; font-size:11px; letter-spacing:0.15em; text-transform:uppercase; margin-top:8px;">Range</div>
      </div>

      <div style="padding:40px; text-align:center; border-right:1px solid #1e293b;">
        <div style="font-size:3rem; font-weight:700; color:white;">7.5</div>
        <div style="color:#0ea5e9; font-size:12px; letter-spacing:0.2em; text-transform:uppercase; margin-top:4px;">kg H₂</div>
        <div style="color:#475569; font-size:11px; letter-spacing:0.15em; text-transform:uppercase; margin-top:8px;">Onboard Storage</div>
      </div>

      <div style="padding:40px; text-align:center; border-right:1px solid #1e293b;">
        <div style="font-size:3rem; font-weight:700; color:white;">3–5</div>
        <div style="color:#0ea5e9; font-size:12px; letter-spacing:0.2em; text-transform:uppercase; margin-top:4px;">min</div>
        <div style="color:#475569; font-size:11px; letter-spacing:0.15em; text-transform:uppercase; margin-top:8px;">Refuel Time</div>
      </div>

      <div style="padding:40px; text-align:center;">
        <div style="font-size:3rem; font-weight:700; color:white;">110</div>
        <div style="color:#0ea5e9; font-size:12px; letter-spacing:0.2em; text-transform:uppercase; margin-top:4px;">kW</div>
        <div style="color:#475569; font-size:11px; letter-spacing:0.15em; text-transform:uppercase; margin-top:8px;">Fuel Cell Output</div>
      </div>

    </div>
  </section>

  <!-- TECHNOLOGY PILLARS -->
  <section style="background:white; padding:100px 40px;">
    <div style="max-width:1100px; margin:0 auto;">
      <p style="font-size:11px; letter-spacing:0.3em; color:#0ea5e9; text-transform:uppercase; margin-bottom:16px;">Architecture</p>
      <h2 style="font-size:clamp(2rem, 4vw, 3.5rem); font-weight:700; color:#0a0f1e; margin-bottom:64px;">Three Systems. One Conviction.</h2>

      <div style="border-top:1px solid #f1f5f9; padding:40px 0; display:grid; grid-template-columns:60px 1fr 2fr 40px; align-items:center; gap:40px;">
        <span style="color:#e2e8f0; font-size:1.1rem;">01</span>
        <h3 style="font-size:1.2rem; font-weight:700; color:#0a0f1e;">Type IV COPV Hydrogen Tank</h3>
        <p style="color:#64748b; font-size:0.9rem; line-height:1.7;">700 bar rated. Carbon fibre overwound. Simulation-validated structural integrity under cyclic fill and thermal variation.</p>
        <span style="color:#0ea5e9; font-size:1.2rem;">→</span>
      </div>

      <div style="border-top:1px solid #f1f5f9; padding:40px 0; display:grid; grid-template-columns:60px 1fr 2fr 40px; align-items:center; gap:40px;">
        <span style="color:#e2e8f0; font-size:1.1rem;">02</span>
        <h3 style="font-size:1.2rem; font-weight:700; color:#0a0f1e;">PEM Fuel Cell Powertrain</h3>
        <p style="color:#64748b; font-size:0.9rem; line-height:1.7;">Proton exchange membrane. 110 kW continuous output. Near-silent operation. Zero tailpipe emissions — water vapour only.</p>
        <span style="color:#0ea5e9; font-size:1.2rem;">→</span>
      </div>

      <div style="border-top:1px solid #f1f5f9; padding:40px 0; display:grid; grid-template-columns:60px 1fr 2fr 40px; align-items:center; gap:40px;">
        <span style="color:#e2e8f0; font-size:1.1rem;">03</span>
        <h3 style="font-size:1.2rem; font-weight:700; color:#0a0f1e;">Intelligent Energy Management</h3>
        <p style="color:#64748b; font-size:0.9rem; line-height:1.7;">Real-time power split between fuel cell and buffer battery. Optimised for Indian drive cycles and long-distance highway demands.</p>
        <span style="color:#0ea5e9; font-size:1.2rem;">→</span>
      </div>

    </div>
  </section>

  <!-- ABOUT PREVIEW -->
  <section style="background:#f8fafc; padding:100px 40px;">
    <div style="max-width:1100px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:center;">
      <div>
        <p style="font-size:11px; letter-spacing:0.3em; color:#0ea5e9; text-transform:uppercase; margin-bottom:20px;">About HySPERA</p>
        <h2 style="font-size:clamp(2rem, 4vw, 3rem); font-weight:700; color:#0a0f1e; line-height:1.1; margin-bottom:32px;">A Founder's Conviction.</h2>
        <p style="color:#475569; font-size:1rem; line-height:1.9; margin-bottom:20px;">
          HySPERA is building India's first premium hydrogen fuel cell passenger car. Founded by a researcher who believes hydrogen is not a distant promise — it is the right answer for long-distance mobility in a country that cannot afford range anxiety or overnight charging.
        </p>
        <p style="color:#475569; font-size:1rem; line-height:1.9; margin-bottom:40px;">
          We are not a component company. We are not a concept studio. We are building the full vehicle. From tank to powertrain to cabin.
        </p>
        <a href="/about" style="color:#0ea5e9; font-size:12px; letter-spacing:0.15em; text-transform:uppercase; text-decoration:none; font-weight:500;">
          Meet the Founder →
        </a>
      </div>
      <div style="background:#e0f2fe; padding:60px 40px; text-align:center;">
        <div style="font-size:4rem; margin-bottom:20px;">⚗️</div>
        <p style="font-weight:700; color:#0a0f1e; font-size:1.1rem;">Kalluri Devi Narasimha Venu Madhav</p>
        <p style="color:#0ea5e9; font-size:11px; letter-spacing:0.2em; text-transform:uppercase; margin-top:8px;">Founder & Lead Engineer</p>
        <p style="color:#64748b; font-size:0.85rem; margin-top:12px;">M.Sc. Hydrogen Technology · TH Rosenheim</p>
      </div>
    </div>
  </section>

  <!-- BLOG PREVIEW -->
  <section style="background:white; padding:100px 40px;">
    <div style="max-width:1100px; margin:0 auto;">
      <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:48px;">
        <div>
          <p style="font-size:11px; letter-spacing:0.3em; color:#0ea5e9; text-transform:uppercase; margin-bottom:12px;">From the Blog</p>
          <h2 style="font-size:clamp(2rem, 4vw, 3rem); font-weight:700; color:#0a0f1e;">Hydrogen Intelligence.</h2>
        </div>
        <a href="/blog" style="color:#0ea5e9; font-size:12px; letter-spacing:0.15em; text-transform:uppercase; text-decoration:none;">View All →</a>
      </div>
      <p style="color:#94a3b8; font-size:0.9rem;">
        19 articles covering PEM fuel cells, hydrogen storage, energy management, EU policy, drivetrain engineering, and the road to clean mobility.
      </p>
    </div>
  </section>

</BaseLayout>
